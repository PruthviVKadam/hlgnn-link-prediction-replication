{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(conda:*)",
      "Bash(git clone:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(nvidia-smi)",
      "Bash(nvidia-smi:*)",
      "Read(./**)",
      "Write(./results/**)",
      "Write(./scripts/**)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Write(./repo/**)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Read(./**/*.env)",
      "Read(./**/secrets/**)",
      "Write(./data/**)"
    ]
  },
  "env": {
    "PYTHONHASHSEED": "0"
  }
}
